class Solution {
  public:
  
    void buildAdjListHelper(unordered_map<int,vector<int>>&adjList,vector<vector<int>>& edges)
    {
        for (int i = 0; i < edges.size(); i++)
        {
            int u = edges[i][0];
            int v = edges[i][1];
        
            adjList[u].push_back(v);
        }
    }  
    
    void topologicalSortUsingDFS(int src,unordered_map<int,vector<int>>&adjList,
    vector<int>&ans,unordered_map<int,bool>&visited)
    {
        visited[src]=true;
        
        for(auto nbr : adjList[src])
        {
            if(!visited[nbr])
            {
                topologicalSortUsingDFS(nbr,adjList,ans,visited);
            }
        }
        
        ans.push_back(src);
        
    }
    vector<int> topoSort(int V, vector<vector<int>>& edges) {
        
        unordered_map<int,vector<int>>adjList;
        buildAdjListHelper(adjList,edges);
        
        unordered_map<int,bool>visited;
        
        vector<int>ans;
        int n=V;
        
        for(int src=0;src<n;src++)
        {
            if(!visited[src])
            {
                topologicalSortUsingDFS(src,adjList,ans,visited);
            }
        }
        
        reverse(ans.begin(),ans.end());
        
        return ans;
        
    }
};
