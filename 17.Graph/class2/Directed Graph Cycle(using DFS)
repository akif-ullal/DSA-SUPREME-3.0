class Solution {
  public:
  
    void buildAdjListHelper(unordered_map<int,vector<int>>&adjList,vector<vector<int>>& edges)
    {
        for (int i = 0; i < edges.size(); i++)
        {
            int u = edges[i][0];
            int v = edges[i][1];
        
            adjList[u].push_back(v);
        }
    }
    
    bool cycleDetectUsingDFS(int src,unordered_map<int,bool>&visted,
    unordered_map<int,vector<int>>&adjList,unordered_map<int,bool>&path)
    {
        visted[src]=true;
        
        for(auto nbr : adjList[src])
        {
            if(!visted[nbr])
            {
                visted[nbr]=true;
                path[src]=true;
                bool ans = cycleDetectUsingDFS(nbr,visted,adjList,path);
                if(ans)
                {
                    return true;
                }
                
            }
            else if(visted[nbr]==true && path[nbr]==true)
            {
                return true;
            }
        }
        
        //backtracking
        path[src]=false;
        return false;
    }
    
    bool isCyclic(int V, vector<vector<int>> &edges) {
        // code here
        unordered_map<int,vector<int>>adjList;
        buildAdjListHelper(adjList,edges);
        
        unordered_map<int,bool>path;
        unordered_map<int,bool>visted;
        int ans = false;
        for(int src=0;src<V;src++)
        {
            if(!visted[src])
            {
                ans = cycleDetectUsingDFS(src,visted,adjList,path);
                if(ans)
                break;
            }
        }
        
        return ans;
        
    }
};
